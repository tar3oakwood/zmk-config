#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>; // 5列(左) + 5列(右) = 10列
        rows = <4>;     // 行数

        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)    RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9)
        >;
    };

    right_transform: keymap_transform_1 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
        /* 右側の列(5-9)を左側の列(0-4)にマッピングする */
        map = <
            RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)  RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)  RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
            RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)  RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
            RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9)  RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
        >;
    };
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";

        col-gpios
            = <&xiao_d 1 GPIO_ACTIVE_HIGH>
            , <&xiao_d 2 GPIO_ACTIVE_HIGH>
            , <&xiao_d 3 GPIO_ACTIVE_HIGH>
            , <&xiao_d 4 GPIO_ACTIVE_HIGH>
            , <&xiao_d 5 GPIO_ACTIVE_HIGH>
            ;

         row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

   };

    /* 実際の物理ピンの定義 */
    leds {
        compatible = "gpio-leds";
        led_red: led_red { gpios = <&gpio0 17 GPIO_ACTIVE_LOW>; };
        led_green: led_green { gpios = <&gpio0 18 GPIO_ACTIVE_LOW>; };
        led_blue: led_blue { gpios = <&gpio0 19 GPIO_ACTIVE_LOW>; };
    };

    /* LEDエイリアスの設定 */
    aliases {
        led-red = &led_red;
        led-green = &led_green;
        led-blue = &led_blue;
    };

    /* ウィジェット用の仮想ノード */
    led_widget: led_widget {
        compatible = "zmk,rgbled-widget";
        label = "RGBLED_WIDGET";
    };
};
